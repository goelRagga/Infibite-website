{
  "name": "ELIVAAS-NEW",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --port",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "start:prettier": "npm-run-all --parallel format start",
    "lint:css": "stylelint 'src/**/*.scss'",
    "lint:ts": "eslint 'src/**/*.{ts,tsx}'",
    "lint": "next lint",
    "prepare": "husky",
    "analyze": "ANALYZE=true npm run build",
    "analyze:bundle": "node scripts/analyze-bundle.mjs analyze",
    "metrics": "node scripts/analyze-bundle.mjs metrics",
    "build:analyze": "npm run build && npm run analyze:bundle",
    "perf:check": "npm run metrics && npm run lint",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,scss}": [
      "prettier --write"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  },
